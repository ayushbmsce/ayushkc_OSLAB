#include <stdio.h>

struct sjf
{
    int pid;
    int at;
    int bt;
    int ct;
    int tat;
    int wt;
    int done;
};

int main()
{
    struct sjf p[100];
    int n,time=0,completed=0;
    int i,shortest;

    printf("enter the number of processes: ");
    scanf("%d",&n);

    for(i=0;i<n;i++)
    {
        p[i].pid=i+1;
        printf("enter arrival time of p%d: ",i+1);
        scanf("%d",&p[i].at);
        printf("enter burst time of p%d: ",i+1);
        scanf("%d",&p[i].bt);
        p[i].done=0;
    }

    while(completed<n)
    {
        shortest=-1;
        for(i=0;i<n;i++)
        {
            if(p[i].at<=time && p[i].done==0)
            {
                if(shortest==-1 || p[i].bt<p[shortest].bt)
                    shortest=i;
            }
        }
        if(shortest==-1)
        {
            time++;
        }
        else
        {
            time+=p[shortest].bt;
            p[shortest].ct=time;
            p[shortest].tat=p[shortest].ct-p[shortest].at;
            p[shortest].wt=p[shortest].tat-p[shortest].bt;
            p[shortest].done=1;
            completed++;
        }
    }

    printf("\nPID\tAT\tBT\tCT\tTAT\tWT\n");
    for(i=0;i<n;i++)
    {
        printf("%d\t%d\t%d\t%d\t%d\t%d\n",p[i].pid,p[i].at,p[i].bt,p[i].ct,p[i].tat,p[i].wt);
    }

    return 0;
}
