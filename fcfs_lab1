#include <stdio.h>

struct fcfs {
    int pid;
    int AT;
    int BT;
    int CT;
    int TAT;
    int WT;
    int RT;
};

int main() {
    int n = 4;
    struct fcfs p[4];

    printf("Enter Arrival Time and Burst Time for 4 processes:\n");
    for (int i = 0; i < n; i++) {
        p[i].pid = i + 1;
        printf("Process %d AT BT: ", p[i].pid);
        scanf("%d %d", &p[i].AT, &p[i].BT);
    }

    for (int i = 0; i < n - 1; i++) {
        for (int j = i + 1; j < n; j++) {
            if (p[i].AT > p[j].AT) {
                struct fcfs temp = p[i];
                p[i] = p[j];
                p[j] = temp;
            }
        }
    }

    int t = 0;
    for (int i = 0; i < n; i++) {
        if (t < p[i].AT) {
            t = p[i].AT;
        }
        t += p[i].BT;
        p[i].CT = t;
        p[i].TAT = p[i].CT - p[i].AT;
        p[i].WT = p[i].TAT - p[i].BT;
        p[i].RT = p[i].WT;
    }


    printf("\nPID\tAT\tBT\tCT\tTAT\tWT\tRT\n");
    for (int i = 0; i < n; i++) {
        printf("%d\t%d\t%d\t%d\t%d\t%d\t%d\n",
               p[i].pid, p[i].AT, p[i].BT,
               p[i].CT, p[i].TAT, p[i].WT, p[i].RT);
    }

    return 0;
}
